{
  "manifest_version": 3,
  "name": "Big Video",
  "version": "1.2",
  "description": "Expands embedded video iframes to full screen with a single click.",
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Big Video"
  },
  "permissions": ["activeTab", "storage"],
  "host_permissions": ["<all_urls>"],
  "browser_specific_settings": {
    "gecko": {
      "id": "gameonhigh@gmail.com",
      "strict_min_version": "126.0"
    }
  }
}
